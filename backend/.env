# Database - using SQLite for local dev (no PostgreSQL needed)
DATABASE_URL=sqlite+aiosqlite:///./argus.db

# Security
SECRET_KEY=argus-dev-secret-key-change-in-production-abcdef123456
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis (optional - for streaks, chat memory)
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=["*"]

# AI Configs (Placeholder for future phases)
GROQ_API_KEY=
GEMINI_API_KEY=

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200